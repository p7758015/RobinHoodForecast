FOOTBALL_DATA_API_KEY=your_key_here
API_FOOTBALL_KEY=your_key_here
OPENAI_API_KEY=your_key_here
TELEGRAM_BOT_TOKEN=your_token_here
# Required for Telegram single-match bot (FlashscoreScraper HTTP service)
FLASHSCORE_SCRAPER_URL=http://localhost:3000
FLASHSCORE_SCRAPER_API_KEY=
FLASHSCORE_SCRAPER_TIMEOUT_S=60
# Normalize free-text league queries via Brave before Flashscore search (fixtures still from scraper).
DISCOVERY_BRAVE_NORMALIZE=true
TELEGRAM_LEAGUE_MAX_MATCHES=5
TELEGRAM_CLARIFICATION_TTL_S=600
EVAL_POOL_DISCOVERY_FALLBACK=true
USE_V2_PIPELINE=false
# Flashscore-first collector (match_meta / standings / form validation)
USE_COLLECTOR_LAYER=false
# Pre-kickoff odds refresh (Refresh A — collector odds only)
ODDS_REFRESH_MAX_AGE_MINUTES=60
ODDS_REFRESH_PRE_KICKOFF_WINDOW_MINUTES=120
USE_OPENCLAW=false
# OpenClaw primary enrichment (default for v2) — Brave is optional fallback only
OPENCLAW_PRIMARY_ENRICHMENT=true
USE_BRAVE_NEWS_ENRICHMENT=false
USE_BRAVE_NEWS_FALLBACK=false
# OpenClaw live enrichment sub-flags
USE_OPENCLAW_LIVE_CONTEXT=true
USE_OPENCLAW_NEWS=true
USE_OPENCLAW_COACH_CONTEXT=true
OPENCLAW_FAIL_SOFT=true
OPENCLAW_CAN_OVERRIDE_FACTUAL=false
OPENCLAW_CAN_OVERRIDE_COACH_NAMES=false
# Brave Search API — news/coach enrichment (requires USE_BRAVE_NEWS_ENRICHMENT=true)
BRAVE_SEARCH_API_KEY=
BRAVE_SEARCH_BASE_URL=https://api.search.brave.com/res/v1/web/search
BRAVE_SEARCH_TIMEOUT_S=15
BRAVE_SEARCH_MAX_RESULTS=8
BRAVE_NEWS_LOOKBACK_HOURS=72
BRAVE_NEWS_MAX_ARTICLES_PER_MATCH=20
BRAVE_NEWS_INCLUDE_COACH_TERMS=true
BRAVE_NEWS_INCLUDE_INJURY_TERMS=true
BRAVE_NEWS_INCLUDE_LINEUP_TERMS=true
BRAVE_COACH_HISTORY_LOOKBACK_DAYS=365
BRAVE_COACH_H2H_LOOKBACK_DAYS=730
BRAVE_COACH_QUOTES_LOOKBACK_DAYS=14
NEWS_REFRESH_MAX_AGE_MINUTES=45
NEWS_REFRESH_PRE_KICKOFF_WINDOW_MINUTES=180
# OpenClaw bridge — stable JSON API for football_agent (preferred over raw gateway)
# Run: python -m football_agent.openclaw_bridge --port 8787 --mode prototype
OPENCLAW_BRIDGE_BASE_URL=http://localhost:8787
OPENCLAW_BRIDGE_MODE=prototype
OPENCLAW_BRIDGE_PORT=8787
# Live-assisted: OpenAI-compatible chat on OpenClaw gateway
OPENCLAW_BRIDGE_API_KEY=
OPENCLAW_BRIDGE_MODEL=gpt-4o-mini
OPENCLAW_BRIDGE_CHAT_PATH=/v1/chat/completions
OPENCLAW_BRIDGE_LIVE_TIMEOUT_S=30
# Upstream OpenClaw gateway for bridge live_assisted (returns HTML on /v1/context)
OPENCLAW_GATEWAY_URL=http://localhost:18789

# Legacy direct OpenClaw gateway (omit when OPENCLAW_BRIDGE_BASE_URL is set)
OPENCLAW_BASE_URL=
OPENCLAW_API_KEY=
OPENCLAW_CONTEXT_BASE_URL=
OPENCLAW_CONTEXT_API_KEY=
OPENCLAW_CONTEXT_TIMEOUT_S=30
# split = GET /v1/context + /v1/odds; unified = GET /v1/enrichment (future-ready)
OPENCLAW_ENRICHMENT_MODE=split
# When true (default), odds are fetched from OpenClaw base if ODDS_SERVICE_URL is unset
OPENCLAW_PROVIDES_ODDS=true
# Optional separate odds service — legacy escape hatch only
ODDS_SERVICE_URL=
ODDS_SERVICE_API_KEY=
ODDS_SERVICE_TIMEOUT_S=30
# Telegram bot runtime (long polling)
BOT_ANALYSIS_TIMEOUT_S=120
BOT_HEALTH_PROBE_TIMEOUT_S=5
# League policy (Stage 3 — competition-agnostic; optional allow/deny lists)
# FootballData scheduled discovery when unset: registry entries with football_data_discoverable=true
# LEAGUE_DISCOVERY_CODES=PL,SA
# LEAGUE_ANALYSIS_ALLOWED_CODES=PL,SA,FS_BOTOLA_PRO
# LEAGUE_EXPRESS_ALLOWED_CODES=PL,SA,FS_BOTOLA_PRO
# LEAGUE_DENY_CODES=
