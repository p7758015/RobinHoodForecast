FOOTBALL_DATA_API_KEY=your_key_here
API_FOOTBALL_KEY=your_key_here
OPENAI_API_KEY=your_key_here
TELEGRAM_BOT_TOKEN=your_token_here
# Required for Telegram single-match bot (FlashscoreScraper HTTP service)
FLASHSCORE_SCRAPER_URL=http://localhost:3000
FLASHSCORE_SCRAPER_API_KEY=
FLASHSCORE_SCRAPER_TIMEOUT_S=60
USE_V2_PIPELINE=false
USE_OPENCLAW=false
# Primary OpenClaw enrichment backend (context + odds) — set when service is deployed
OPENCLAW_BASE_URL=
OPENCLAW_API_KEY=
# Legacy alias; used if OPENCLAW_BASE_URL is empty
OPENCLAW_CONTEXT_BASE_URL=
OPENCLAW_CONTEXT_API_KEY=
OPENCLAW_CONTEXT_TIMEOUT_S=30
# split = GET /v1/context + /v1/odds; unified = GET /v1/enrichment (future-ready)
OPENCLAW_ENRICHMENT_MODE=split
# When true (default), odds are fetched from OpenClaw base if ODDS_SERVICE_URL is unset
OPENCLAW_PROVIDES_ODDS=true
# Optional separate odds service — legacy escape hatch only
ODDS_SERVICE_URL=
ODDS_SERVICE_API_KEY=
ODDS_SERVICE_TIMEOUT_S=30
# Telegram bot runtime (long polling)
BOT_ANALYSIS_TIMEOUT_S=120
BOT_HEALTH_PROBE_TIMEOUT_S=5
